Project mercari_clone {
  database_type: "MySQL"
}

Table users {
  id bigint [pk, increment]
  name varchar(255)
  email varchar(255) [unique]
  password varchar(255)
  image varchar(255) [note:'保存パスを追加']
  email_verified_at datetime [note: 'メール認証に使用']
  remember_token varchar(100) [note: 'ログイン保持用']
  created_at datetime
  updated_at datetime
}

Table addresses {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  postal_code varchar(20) [note: '数値型にしてしまうと先頭の0が消える。また足し算など演算の必要もないのでvarchar型で十分。また海外対応などへの拡張を考慮すると7桁という数字に限定しない方がいい。']
  prefecture varchar(100)
  city varchar(100)
  address_line varchar(255)
  phone_number varchar(20)
  created_at datetime
  updated_at datetime
}

Table items {
  id bigint [pk, increment]
  user_id bigint [ref: > users.id]
  title varchar(255)
  brand_name varchar(255)
  category_id bigint [ref: > categories.id]
  description text
  price int
  status varchar(255) [note:"on_sale,sold"]
  created_at datetime
  updated_at datetime
}

Table item_images {
  id bigint [pk, increment]
  item_id bigint [ref: > items.id]
  image_url varchar(255)
  sort_order int [default: 1] // 並び順指定
  created_at datetime
  updated_at datetime
}

Table orders {
  id bigint [pk, increment]
  buyer_id bigint [ref: > users.id]
  item_id bigint [ref: > items.id]
  address_id bigint [ref: > addresses.id]
  status varchar(255) [note:"pending,confirmed,shipped,completed,cancelled,refunded" ,not null, default: 'pending']
  payment_method varchar(255) [note:"コンビニ払い,カード支払い"]
  created_at datetime
  updated_at datetime
}

Table comments {
  id bigint [pk, increment]
  item_id bigint [ref: > items.id]
  user_id bigint [ref: > users.id]
  content text
  created_at datetime
}

Table likes {
  id bigint [pk, increment]
  item_id bigint [ref: > items.id]
  user_id bigint [ref: > users.id]
  created_at datetime
}

Table categories {
  id bigint [pk, increment]
  key varchar(100) [unique] // 例: 'fashion'
  label varchar(100)        // 表示名: 'ファッション'
  sort_order int [notnull default:1]           // 並び順
  created_at datetime
  updated_at datetime
}